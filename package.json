{
  "name": "@editorjs/image",
  "version": "2.10.3",
  "keywords": [
    "codex editor",
    "image",
    "editor.js",
    "editorjs"
  ],
  "description": "Image Tool for Editor.js",
  "license": "MIT",
  "repository": "https://github.com/editor-js/image",
  "files": [
    "dist"
  ],
  "main": "./dist/image.umd.js",
  "module": "./dist/image.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/image.mjs",
      "require": "./dist/image.umd.js"
    }
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"node ./dev/server.js\"",
    "build": "vite build",
    "lint": "eslint",
    "lint:errors": "eslint --quiet",
    "lint:fix": "eslint --fix"
  },
  "author": {
    "name": "CodeX",
    "email": "team@ifmo.su"
  },
  "devDependencies": {
    "@codexteam/ajax": "^4.2.0",
    "@editorjs/editorjs": "2.30.0-rc.12",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.0.1",
    "eslint": "^9.7.0",
    "eslint-webpack-plugin": "^5.0.3",
    "formidable": "^3.5.1",
    "postcss-nested": "^6.0.1",
    "postcss-nested-ancestors": "^3.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^3.5.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@codexteam/icons": "^0.3.0"
  }
}
